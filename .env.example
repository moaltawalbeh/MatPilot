# ============================================
# MatPilot — Environment Variables
# ============================================
# Copy this file to .env and fill in values.
# All variables have sensible development defaults.

# ── Environment ──────────────────────────────
# development | staging | production
MATPILOT_ENV=development

# ── API Server ───────────────────────────────
MATPILOT_API_HOST=0.0.0.0
MATPILOT_API_PORT=8000

# Comma-separated list of allowed CORS origins.
# In development, defaults to http://localhost:3000,http://localhost:3001.
# In production, set this to your frontend domain(s).
# Example: https://matpilot.vercel.app,https://staging.matpilot.app
MATPILOT_CORS_ORIGINS=

# ── Database ─────────────────────────────────
# PostgreSQL connection string (required for Render deployment)
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# ── Storage ──────────────────────────────────
# local | s3 | azure | gcs
MATPILOT_STORAGE_BACKEND=local
MATPILOT_STORAGE_PATH=./storage

# S3 (when MATPILOT_STORAGE_BACKEND=s3)
MATPILOT_S3_BUCKET=
MATPILOT_S3_REGION=

# Azure Blob (when MATPILOT_STORAGE_BACKEND=azure)
MATPILOT_AZURE_CONTAINER=

# Google Cloud Storage (when MATPILOT_STORAGE_BACKEND=gcs)
MATPILOT_GCS_BUCKET=

# ── Uploads ──────────────────────────────────
MATPILOT_TEMP_DIR=
MATPILOT_MAX_FILE_SIZE=52428800

# ── Analysis ─────────────────────────────────
MATPILOT_MAX_JOBS=4
MATPILOT_JOB_TIMEOUT=300
MATPILOT_DEFAULT_WAVELENGTH=1.5406

# ── Reference Database ──────────────────────
MATPILOT_CIF_CACHE_DIR=data/cif_cache
MATPILOT_COD_API_URL=https://www.crystallography.net/cod
MATPILOT_CACHE_TTL=3600
MATPILOT_SEARCH_TIMEOUT=30

# ── Logging ──────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
MATPILOT_LOG_LEVEL=INFO
MATPILOT_LOG_STRUCTURED=true
